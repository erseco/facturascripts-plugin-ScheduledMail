    Read-only detail of a scheduled email.
-->
<view>
    <columns>
        <group name="status" title="status" numcolumns="12">
            <column name="status" numcolumns="2" order="10">
                <widget type="text" fieldname="status" readonly="true"/>
            </column>
            <column name="scheduled-at" numcolumns="3" order="20">
                <widget type="datetime" fieldname="scheduled_at" required="true"/>
            </column>
            <column name="sent-at" numcolumns="3" order="30">
                <widget type="datetime" fieldname="sent_at" readonly="true"/>
            </column>
            <column name="creation-date" numcolumns="2" order="40">
                <widget type="datetime" fieldname="creation_date" readonly="true"/>
            </column>
            <column name="user" numcolumns="2" order="50">
                <widget type="text" fieldname="nick" readonly="true"/>
            </column>
        </group>
        <group name="email" title="email" numcolumns="12">
            <column name="from" numcolumns="4" order="10">
                <widget type="text" fieldname="email_from" readonly="true"/>
            </column>
            <column name="email-to" numcolumns="4" order="20">
                <widget type="text" fieldname="email_to" required="true"/>
            </column>
            <column name="email-cc" numcolumns="4" order="30">
                <widget type="text" fieldname="email_cc"/>
            </column>
            <column name="email-bcc" numcolumns="4" order="40">
                <widget type="text" fieldname="email_bcc"/>
            </column>
            <column name="subject" numcolumns="8" order="50">
                <widget type="text" fieldname="subject"/>
            </column>
            <column name="body" numcolumns="12" order="60">
                <widget type="textarea" fieldname="body"/>
            </column>
        </group>
        <group name="details" title="details" numcolumns="12">
            <column name="model-class" numcolumns="3" order="10">
                <widget type="text" fieldname="model_class_name" readonly="true"/>
            </column>
            <column name="model-code" numcolumns="3" order="20">
                <widget type="text" fieldname="model_code" readonly="true"/>
            </column>
            <column name="error" numcolumns="12" order="30">
                <widget type="textarea" fieldname="error" readonly="true"/>
            </column>
        </group>
    </columns>
</view>
